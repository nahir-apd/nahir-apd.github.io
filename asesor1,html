<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; background: #f4f7f6; }
        .header-box { background: linear-gradient(135deg, #001f3f 0%, #333 100%); padding: 40px; border-radius: 15px 15px 0 0; color: white; }
        .content-box { background: white; padding: 30px; border-radius: 0 0 15px 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #eee; }
        th { color: #888; font-size: 0.8rem; text-transform: uppercase; }
        .badge { background: #e8f4fd; color: #001f3f; padding: 5px 10px; border-radius: 5px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="header-box">
        <span style="font-size: 0.7rem; letter-spacing: 2px; opacity: 0.7;">OFFICIAL ASESOR BREADCRUMB</span>
        <h1 style="margin: 10px 0;">LSP Politeknik Negeri Ujung Pandang</h1>
        <p>Asesor Kompetensi Internal - Administrasi Perkantoran Digital</p>
    </div>
    <div class="content-box">
        <h3><i class="fas fa-list-check"></i> Daftar Skema & Lisensi</h3>
        <table>
            <thead>
                <tr><th>Nama Skema</th><th>Kualifikasi</th><th>Target Asesi</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Skema Digital Administration</strong></td>
                    <td>Level VI (Diploma)</td>
                    <td><span class="badge">Mahasiswa APD</span></td>
                </tr>
                <tr>
                    <td><strong>Skema Teknisi Akuntansi</strong></td>
                    <td>Level V</td>
                    <td><span class="badge">Mahasiswa Akuntansi</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</body>
</html>
