<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 0; padding: 20px; background: #f4f7f6; }
        .box { background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .header { background: #001f3f; color: white; padding: 30px; }
        .content { padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        th, td { padding: 12px; border-bottom: 1px solid #eee; text-align: left; }
        .badge { background: #e8f4fd; color: #001f3f; padding: 5px 10px; border-radius: 5px; font-weight: bold; font-size: 0.8rem; }
    </style>
</head>
<body>
    <div class="box">
        <div class="header">
            <h1 style="margin:0;">LSP P1 PNUP</h1>
            <p style="margin:5px 0 0 0; opacity:0.8;">Asesor Kompetensi Internal</p>
        </div>
        <div class="content">
            <h3>Daftar Skema</h3>
            <table>
                <tr>
                    <th>Skema</th>
                    <th>Target</th>
                </tr>
                <tr>
                    <td><strong>Digital Administration</strong></td>
                    <td><span class="badge">Mahasiswa APD</span></td>
                </tr>
                <tr>
                    <td><strong>Teknisi Akuntansi</strong></td>
                    <td><span class="badge">Mahasiswa Akuntansi</span></td>
                </tr>
            </table>
        </div>
    </div>
</body>
</html>
